#version 460
#extension GL_GOOGLE_include_directive : enable
#include "common.glsl"
#include "helpers.glsl"

// ============================================================================
// density.comp - δ-plus WCSPH density + pressure update (stage 4 of leapfrog).
//
// Consumes correction outputs (M^-1, ∇ρ) and current-step density
// (density_pressure_a). Runs a 27-voxel neighbor loop per particle to
// compute:
//   density_drift     = Σ_j  -ρ_i · V_j · (v_j - v_i) · ∇W̃_ij
//   density_diffusion = Σ_j   δ · h · c₀ · D_ij           (Antuono δ-SPH)
//   D_ij              = 2 · ψ_ij · (-x_ij · ∇W̃_ij) / (r² + ε_h²) · V_j
//   ψ_ij              = (ρ_j - ρ_i) - 0.5 · (M_i·∇ρ_i + M_j·∇ρ_j) · (-x_ij)
//
//   ∇W̃_ij = M_i · ∇W_ij   (KCG-corrected gradient, using self's correction)
//   x_ij   = r_i - r_j
//
// Forward integration: ρ_{n+1} = ρ_n + dt · (drift + diffusion)
// EOS:                 P_{n+1} = eos_constant · ((ρ_{n+1}/ρ₀)^γ - 1)
//
// Writes to the ping-pong "write" buffer (density_pressure_b). Next step's
// descriptor swap makes it the "read" side.
//
// Indexing: 1-based throughout. particle_id ∈ [1, pool_size],
// voxel_id ∈ [1, voxel_count], slot entries are direct 1-based particle_ids.
//
// V0-a: single GPU, no ghost lookup. No multi-phase rest_density scaling.
// ============================================================================

layout(local_size_x_id = 51, local_size_y = 1, local_size_z = 1) in;

// ============================================================================
// Main
// ============================================================================
void main() {
    // 0-based invocation → 1-based particle_id.
    uint self_particle_id = gl_GlobalInvocationID.x + 1u;

    // Padding threads (dispatch rounds up to WORKGROUP_SIZE): early-return.
    if (self_particle_id > POOL_SIZE) return;

    // Read material params (used for EOS at end) and skip inlet particles
    // (their state has no SPH meaning; they never appear as neighbors per the
    // InsideParticleIndexBuffer invariants in common.glsl).
    uint self_group_id = material[self_particle_id];
    MaterialParameters self_params = material_parameters[self_group_id];
    if (self_params.kind == MATERIAL_INLET) return;

    // --- Read self state -----------------------------------------------------
    vec4  self_position_voxel_id = position_voxel_id[self_particle_id];
    vec3  self_position          = self_position_voxel_id.xyz;
    uint  self_voxel_id          = uint(round(self_position_voxel_id.w));
    if (self_voxel_id == VOXEL_ID_DEAD) return;

    vec3  self_velocity = velocity_mass[self_particle_id].xyz;
    float self_density  = density_pressure_a[self_particle_id].x;   // ρ_n

    // KCG correction matrix and density gradient from correction.comp output.
    // When USE_KCG_CORRECTION is false (ablation), substitute identity / zero
    // — reduces this kernel to plain δ-SPH (Antuono 2012) without the kernel
    // gradient correction. The branch is on a spec constant, so glslc -O
    // dead-code-eliminates one side at compile time (no runtime cost).
    mat3 self_correction_matrix;
    vec3 self_density_gradient;
    if (USE_KCG_CORRECTION) {
        self_correction_matrix = unpack_correction_inverse(self_particle_id);
        self_density_gradient  = density_gradient_kernel_sum[self_particle_id].xyz;
    } else {
        self_correction_matrix = mat3(1.0);
        self_density_gradient  = vec3(0.0);
    }

    // Corrected self density gradient (loop-invariant)
    vec3 self_corrected_density_gradient = self_correction_matrix * self_density_gradient;

    // --- Decode self voxel coord ---------------------------------------------
    ivec3 self_voxel_coord = own_coord_of(self_voxel_id);

    // --- Accumulators --------------------------------------------------------
    float density_drift     = 0.0;
    float density_diffusion = 0.0;

    int neighbor_z_range = int(NEIGHBOR_Z_RANGE);

    // ------------------------------------------------------------------------
    // 27-voxel neighbor loop (9 in 2D).
    // ------------------------------------------------------------------------
    for (int delta_z = -neighbor_z_range; delta_z <= neighbor_z_range; delta_z++) {
        for (int delta_y = -1; delta_y <= 1; delta_y++) {
            for (int delta_x = -1; delta_x <= 1; delta_x++) {
                ivec3 neighbor_coord = self_voxel_coord + ivec3(delta_x, delta_y, delta_z);
                if (!in_own_grid(neighbor_coord)) continue;
                // V1 TODO: else if (GHOST_DIMENSION_X > 0u) { check ghost grid }

                uint neighbor_voxel_id = own_voxel_id_of(neighbor_coord);
                uint neighbor_voxel_particle_count = inside_particle_count[neighbor_voxel_id];

                for (uint slot_index = 0u; slot_index < neighbor_voxel_particle_count; slot_index++) {
                    uint neighbor_particle_id = inside_particle_index[neighbor_voxel_id * MAX_PARTICLES_PER_VOXEL + slot_index];
                    if (neighbor_particle_id == INSIDE_SLOT_EMPTY) break;
                    if (neighbor_particle_id == self_particle_id) continue;

                    // Skip boundary↔boundary pair when self is boundary. The
                    // boundary's per-step new_density (and the new_pressure
                    // derived from it via EOS) should reflect ONLY fluid
                    // neighbor influence, not artifacts from other boundaries
                    // — those are static and contribute zero divergence but
                    // their kernel-deficient drift terms still feed back into
                    // the boundary's apparent pressure. Branch is uniform per
                    // workgroup since voxel-sorted boundaries cluster together.
                    if (self_params.kind == MATERIAL_BOUNDARY) {
                        uint neighbor_group_id = material[neighbor_particle_id];
                        if (material_parameters[neighbor_group_id].kind == MATERIAL_BOUNDARY) continue;
                    }

                    // --- Distance check (Wendland C4 support = h) -----------
                    // Neighbor is guaranteed non-inlet / non-dead by InsideParticleIndexBuffer invariants.
                    vec3  neighbor_position = position_voxel_id[neighbor_particle_id].xyz;
                    vec3  position_difference_neighbor_to_self = self_position - neighbor_position; // x_ij
                    float distance = length(position_difference_neighbor_to_self);
                    if (distance >= SMOOTHING_LENGTH || distance < 1e-12) continue;

                    // --- Read neighbor state --------------------------------
                    vec3  neighbor_velocity = velocity_mass[neighbor_particle_id].xyz;
                    float neighbor_mass     = velocity_mass[neighbor_particle_id].w;
                    float neighbor_density  = density_pressure_a[neighbor_particle_id].x;
                    float neighbor_volume   = neighbor_mass / neighbor_density;

                    // Read neighbor correction matrix and density gradient
                    // (or identity / zero when KCG ablated; spec-const DCE'd).
                    mat3 neighbor_correction_matrix;
                    vec3 neighbor_density_gradient;
                    if (USE_KCG_CORRECTION) {
                        neighbor_correction_matrix = unpack_correction_inverse(neighbor_particle_id);
                        neighbor_density_gradient  = density_gradient_kernel_sum[neighbor_particle_id].xyz;
                    } else {
                        neighbor_correction_matrix = mat3(1.0);
                        neighbor_density_gradient  = vec3(0.0);
                    }

                    // --- Kernel gradient: raw then M_i-corrected ------------
                    vec3 raw_gradient        = evaluate_kernel_gradient(position_difference_neighbor_to_self, distance);
                    vec3 corrected_gradient  = self_correction_matrix * raw_gradient;

                    // --- δ-SPH density diffusion (gated by USE_DENSITY_DIFFUSION) -
                    // Spec-const branch: glslc -O DCE-removes the entire body when
                    // USE_DENSITY_DIFFUSION = false → vanilla WCSPH continuity.
                    if (USE_DENSITY_DIFFUSION) {
                        // --- ψ_ij ---------------------------------------------------
                        // V0 simplification: ψ_ij = (ρ_j - ρ_i) only (linear form).
                        // Full Antuono δ-plus formulation also includes an antisymmetric
                        // density-gradient projection term that improves accuracy near
                        // sharp density jumps:
                        //   ψ_ij = (ρ_j - ρ_i) - 0.5 · (M_i·∇ρ_i + M_j·∇ρ_j) · (-x_ij)
                        // The second term is intentionally commented out for V0 to keep
                        // the operator simple while validating the rest of the pipeline.
                        // The supporting computations below (corrected gradient sums) are
                        // also kept so the second term can be restored by uncommenting.
                        vec3 neighbor_corrected_density_gradient = neighbor_correction_matrix * neighbor_density_gradient;
                        vec3 corrected_density_gradient_sum = self_corrected_density_gradient + neighbor_corrected_density_gradient;
                        vec3 position_difference_self_to_neighbor = -position_difference_neighbor_to_self; // -x_ij
                        float psi_ij = (neighbor_density - self_density);// - 0.5 * dot(corrected_density_gradient_sum, position_difference_self_to_neighbor);

                        // --- D_ij = 2·ψ_ij · (-x_ij · ∇W̃_ij) / (r² + ε_h²) · V_j ---
                        float dot_xji_gradient = dot(position_difference_self_to_neighbor, corrected_gradient);
                        float d_ij = 2.0 * psi_ij * dot_xji_gradient / (distance * distance + EPS_H_SQUARED) * neighbor_volume;

                        // --- Diffusion accumulator: δ · h · c₀ · D_ij ---------
                        density_diffusion += DELTA_COEFFICIENT * SMOOTHING_LENGTH * SPEED_OF_SOUND * d_ij;
                    }

                    // --- Drift: -ρ_i · V_j · (v_j - v_i) · ∇W̃_ij -----------
                    density_drift += -self_density * neighbor_volume * dot(neighbor_velocity - self_velocity, corrected_gradient);
                }
            }
        }
    }

    // ========================================================================
    // Forward integration (full dt; leapfrog only staggers v, not ρ).
    // ========================================================================
    float new_density = self_density + TIMESTEP * (density_drift + density_diffusion);

    // ========================================================================
    // Tait EOS: P = eos_constant · ((ρ/ρ₀)^γ - 1)
    // ========================================================================
    float density_ratio = new_density / self_params.rest_density;
    float new_pressure  = self_params.eos_constant * (pow(density_ratio, POWER_PARAMETER) - 1.0);

    // ========================================================================
    // Write to ping-pong B (next-step canonical ρ, P).
    //
    // Boundary handling: store ρ₀ instead of the integrated new_density so that
    // boundary particles' density does NOT accumulate step-to-step (this is
    // what kills the boundary density drift). The pressure stored is still the
    // freshly-computed new_pressure (= EOS(new_density)) — force.comp this step
    // reads it for fluid↔boundary pressure interactions, so the boundary still
    // reacts to local pressure conditions. Next step's density.comp reads back
    // ρ₀ for the boundary source density (no drift), and force.comp computes
    // V_j_boundary = m / ρ₀ = V_calibrated (constant, physically correct for
    // a static solid). Matches the legacy "property buffer = ρ₀ forever,
    // runtime buffer = per-step new_pressure" architecture.
    // ========================================================================
    float density_to_store = (self_params.kind == MATERIAL_BOUNDARY)
        ? self_params.rest_density
        : new_density;
    density_pressure_b[self_particle_id] = vec2(density_to_store, new_pressure);
}
