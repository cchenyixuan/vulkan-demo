#version 460
#extension GL_GOOGLE_include_directive : enable
#include "common.glsl"
#include "helpers.glsl"

// ============================================================================
// predict.comp - leapfrog kick + drift + voxel-crossing detection (stage 1).
//
// For each active fluid particle:
//   1. Leapfrog kick   : v_{n+1/2} = v_{n-1/2} + a_n · dt
//   2. Drift           : x_{n+1}   = x_n + v_{n+1/2} · dt + shift_n
//   3. Voxel crossing  : compute new voxel_id; if != old, atomic-append particle_id
//                        to incoming_particle_index of the new voxel.
//   4. Open boundary   : if new position lies outside the grid, kill the particle
//                        (zero position + velocity, voxel_id = 0).
//
// Skipped kinds: BOUNDARY (static), ROTOR (deferred coupling), INLET (emitter).
// Dead particles (old voxel_id = 0) also skip.
//
// Data flow:
//   acceleration[pid]  : written by previous step's force.comp  (a_n)
//   shift[pid]         : written by previous step's force.comp  (shift_n, already M_i-corrected)
//   position_voxel_id  : read (x_n + old vid) → write (x_{n+1} + new vid)
//   velocity_mass.xyz  : read (v_{n-1/2}) → write (v_{n+1/2}); mass preserved
//
// Voxel buffer writes:
//   incoming_particle_count[new_vid]  : atomicAdd +1 on crossing
//   incoming_particle_index[...]      : atomic append (if within CAP)
//   On overflow (slot >= CAP): log to GlobalStatus, kill particle.
//
// Invariant for downstream update_voxel.comp:
//   - incoming_particle_count may exceed MAX_INCOMING_PER_VOXEL after overflow;
//     update_voxel MUST clamp its iteration bound to min(count, CAP).
//   - Dead particles (killed here) have position_voxel_id.w = 0, so update_voxel
//     automatically compacts them out of inside_particle_index.
// ============================================================================

layout(local_size_x_id = 51, local_size_y = 1, local_size_z = 1) in;

// Zero out particle state on death. Stale shift / acceleration / density fields
// remain in their buffers, but voxel_id == 0 gates all downstream kernels from
// reading them. Slot stays unused until future inlet spawn / defrag reclaims it.
void kill_particle(uint particle_id) {
    position_voxel_id[particle_id] = vec4(0.0);
    velocity_mass[particle_id]     = vec4(0.0);
}

void main() {
    uint self_particle_id = gl_GlobalInvocationID.x + 1u;
    if (self_particle_id > POOL_SIZE) return;

    // --- Material kind gate: skip all non-fluid kinds in V0 ------------------
    uint self_group_id = material[self_particle_id];
    MaterialParameters self_params = material_parameters[self_group_id];
    if (self_params.kind == MATERIAL_BOUNDARY) return;   // static walls
    if (self_params.kind == MATERIAL_ROTOR)    return;   // V0: coupling deferred
    if (self_params.kind == MATERIAL_INLET)    return;   // emitter templates

    // --- Read self position + voxel_id ---------------------------------------
    vec4 self_position_voxel_id = position_voxel_id[self_particle_id];
    vec3 self_position          = self_position_voxel_id.xyz;
    uint old_voxel_id           = uint(round(self_position_voxel_id.w));
    if (old_voxel_id == VOXEL_ID_DEAD) return;   // already dead

    // --- Read velocity + mass + acceleration + shift -------------------------
    vec4  self_velocity_mass = velocity_mass[self_particle_id];
    vec3  self_velocity_half = self_velocity_mass.xyz;          // v_{n-1/2}
    float self_mass          = self_velocity_mass.w;

    vec3  self_acceleration  = acceleration[self_particle_id].xyz;  // a_n
    vec3  self_shift         = shift[self_particle_id].xyz;          // shift_n (M_i-corrected)

    // ========================================================================
    // Leapfrog kick (full-step, combining Verlet KDK's two half-kicks):
    //     v_{n+1/2} = v_{n-1/2} + a_n · dt
    // ========================================================================
    vec3 new_velocity = self_velocity_half + self_acceleration * TIMESTEP;

    // ========================================================================
    // Drift:
    //     x_{n+1} = x_n + v_{n+1/2} · dt + shift_n
    // ========================================================================
    vec3 new_position = self_position + new_velocity * TIMESTEP + self_shift;

    // ========================================================================
    // Determine new voxel_id.
    // Spatial coord is 0-based; convert via OWN_ORIGIN + SMOOTHING_LENGTH lattice.
    // ========================================================================
    vec3  own_origin = vec3(OWN_ORIGIN_X, OWN_ORIGIN_Y, OWN_ORIGIN_Z);
    ivec3 new_voxel_coord  = ivec3(floor((new_position - own_origin) / SMOOTHING_LENGTH));

    // Case C: drifted out of domain → kill (open boundary).
    if (!in_own_grid(new_voxel_coord)) {
        kill_particle(self_particle_id);
        return;
    }

    uint new_voxel_id = own_voxel_id_of(new_voxel_coord);

    // ========================================================================
    // Case B: voxel changed → atomic-append to new voxel's incoming queue.
    // ========================================================================
    if (new_voxel_id != old_voxel_id) {
        uint slot = atomicAdd(incoming_particle_count[new_voxel_id], 1u);
        if (slot >= MAX_INCOMING_PER_VOXEL) {
            // Incoming buffer full for target voxel → log + kill.
            // Counter stays past CAP (update_voxel clamps on read).
            // CompSwap below stores ONE example overflow voxel (race winner
            // when the field is still 0); subsequent overflows cannot overwrite.
            atomicAdd(overflow_incoming_count, 1u);
            atomicCompSwap(first_overflow_voxel_incoming, 0u, new_voxel_id);
            kill_particle(self_particle_id);
            return;
        }
        incoming_particle_index[new_voxel_id * MAX_INCOMING_PER_VOXEL + slot] = self_particle_id;
    }
    // Case A: new_voxel_id == old_voxel_id → no atomic op; particle stays in
    // the current voxel's inside list and update_voxel sees no change.

    // ========================================================================
    // Write updated state (only Cases A and B reach here).
    // ========================================================================
    position_voxel_id[self_particle_id] = vec4(new_position, float(new_voxel_id));
    velocity_mass[self_particle_id]     = vec4(new_velocity, self_mass);
}
